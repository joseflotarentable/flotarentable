{
  "rewrites": [
    { "source": "/((?!sitemap.xml|robots.txt|assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(icon-32|icon-180|icon-192|icon-512|favicon|og-image|site.webmanifest)(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
